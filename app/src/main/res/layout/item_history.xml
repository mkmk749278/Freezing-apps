<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Action icon (freeze/unfreeze) -->
        <ImageView
            android:id="@+id/actionIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="@string/action_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorPrimary"
            tools:src="@drawable/ic_freeze" />

        <!-- App name -->
        <TextView
            android:id="@+id/historyAppName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/statusIcon"
            app:layout_constraintStart_toEndOf="@id/actionIcon"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="App Name" />

        <!-- Action text -->
        <TextView
            android:id="@+id/historyAction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            app:layout_constraintEnd_toStartOf="@id/statusIcon"
            app:layout_constraintStart_toEndOf="@id/actionIcon"
            app:layout_constraintTop_toBottomOf="@id/historyAppName"
            tools:text="Frozen" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/historyTimestamp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintEnd_toStartOf="@id/statusIcon"
            app:layout_constraintStart_toEndOf="@id/actionIcon"
            app:layout_constraintTop_toBottomOf="@id/historyAction"
            tools:text="Jan 01, 2024 12:00:00" />

        <!-- Success/failure icon -->
        <ImageView
            android:id="@+id/statusIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/status"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_success" />

        <!-- Error message -->
        <TextView
            android:id="@+id/historyError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/error_color"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/actionIcon"
            app:layout_constraintTop_toBottomOf="@id/historyTimestamp"
            tools:text="Error: permission denied" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
